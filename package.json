{
  "name": "freestyle",
  "version": "0.0.1",
  "description": "Open-source AI voice dictation — local-first, BYOK cloud.",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "postinstall": "node scripts/fix-keylistener.mjs",
    "dev": "electron-vite dev",
